# ================================================================
# SuperAI V11 - local development environment
# Copy this file to .env and adjust values only when you need an override.
# Leave feature flags and SUPERAI_MODE unset here so config/config.yaml stays authoritative.
# ================================================================

# Core runtime
SECRET_KEY=superai-local-dev-secret-change-in-production
SERVER__HOST=0.0.0.0
SERVER__PORT=8000
SERVER__ENVIRONMENT=development
MODELS__DEVICE=auto
MODELS__PRIMARY=Qwen/Qwen2.5-0.5B-Instruct
MODELS__LOAD_TIMEOUT_S=180
MEMORY__ENABLED=true
MEMORY__DB_PATH=data/superai.db
FEEDBACK__ENABLED=true
FEEDBACK__STORE_PATH=data/feedback.db
SECURITY__REQUIRE_AUTH=false
SECURITY__BANDIT_SCAN=true
LOGGING__LEVEL=INFO
LOGGING__FORMAT=text
LOGGING__FILE=logs/superai.log
SKILLS__AUTO_ACTIVATE_ALL=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_ENABLE_ADVANCED_TABS=true

# External integrations (optional placeholders)
HF_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
SENTRY_DSN=
GRAFANA_PASSWORD=superai_admin

# Optional overrides (commented out to avoid masking config/config.yaml)
# SUPERAI_MODE=advanced
# FEATURES__ENABLE_RLHF=true
