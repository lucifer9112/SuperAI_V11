# ================================================================
# SuperAI V11 - .env.example -> copy to .env, fill in secrets
# ================================================================

SECRET_KEY=change-me-to-a-random-64-char-string
MODELS__DEVICE=auto
SERVER__PORT=8000
SERVER__ENVIRONMENT=development
SUPERAI_MODE=minimal
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
HF_TOKEN=
SENTRY_DSN=
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
LOGGING__LEVEL=INFO

# Feature flags (set SUPERAI_MODE=advanced to use these)
FEATURES__ENABLE_REFLECTION=false
FEATURES__ENABLE_LEARNING=false
FEATURES__ENABLE_ADVANCED_MEMORY=false
FEATURES__ENABLE_PARALLEL_AGENTS=false
FEATURES__ENABLE_RAG=false
FEATURES__ENABLE_SELF_IMPROVEMENT=false
FEATURES__ENABLE_MODEL_REGISTRY=false
FEATURES__ENABLE_AI_SECURITY=false
FEATURES__ENABLE_MULTIMODAL=false
FEATURES__ENABLE_DISTRIBUTED=false
FEATURES__ENABLE_PERSONALITY=false
FEATURES__ENABLE_RLHF=false
FEATURES__ENABLE_TOOLS=false
FEATURES__ENABLE_CONSENSUS=false
FEATURES__ENABLE_WORKFLOW=false
FEATURES__ENABLE_SKILLS=false
FEATURES__ENABLE_CODE_REVIEW=false
FEATURES__ENABLE_DEBUGGING=false
FEATURES__ENABLE_CONTEXT=false
FEATURES__ENABLE_JUDGE=false
FEATURES__ENABLE_COGNITIVE=false
FEATURES__ENABLE_VOICE=false
FEATURES__ENABLE_VISION=false
FEATURES__ENABLE_FEEDBACK=false
FEATURES__ENABLE_AGENT=false
